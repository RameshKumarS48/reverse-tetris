{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "reverse-tetris",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",
  "routes": [
    {
      "pattern": "untetris.rameshkumar.space/*",
      "zone_name": "rameshkumar.space"
    }
  ]
}
